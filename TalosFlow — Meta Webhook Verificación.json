      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst entry = body?.entry?.[0];\nconst change = entry?.changes?.[0]?.value;\nconst message = change?.messages?.[0];\nconst contact = change?.contacts?.[0];\nif (!message?.text?.body) return [{ json: { valid: false } }];\nreturn [{ json: { valid: true, from_phone: message.from, contact_name: contact?.profile?.name || 'Cliente WhatsApp', text: message.text.body, wa_message_id: message.id } }];"
      },
