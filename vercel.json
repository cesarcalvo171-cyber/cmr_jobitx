{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/followup",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/notify",
      "schedule": "0 18 * * *"
    }
  ]
}
